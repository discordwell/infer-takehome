# USAA's Akamai edge currently requires headed Chromium.
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOWMO_MS=0

SESSION_TTL_SECONDS=1800

# Dev: swap the active carrier flow for a deterministic mock (no real network)
CARRIER_MOCK=false
MOCK_BAD_PASSWORD=false
MOCK_BAD_MFA=false
MOCK_SKIP_MFA=false
MOCK_QUICK_PATH_OK=true

# Credentials for the live smoke tests (tests/test_*_smoke.py)
GEICO_USERNAME=
GEICO_PASSWORD=
USAA_USERNAME=
USAA_PASSWORD=
USAA_MFA_EMAIL=

# Convenience: when true, GET /api/dev/credentials returns the env-saved
# creds so the UI can pre-fill the form during local demos. Leave off in prod.
DEV_PREFILL_CREDS=false
