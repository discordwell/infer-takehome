# USAA's Akamai edge currently requires headed Chromium.
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOWMO_MS=0

SESSION_TTL_SECONDS=1800
MFA_TIMEOUT_SECONDS=300
USAA_QUICK_PATH_MAX_AGE_SECONDS=300
USAA_LOGIN_DRIVER=os_browser
USAA_OS_BROWSER_PROFILE_DIR=storage/browser-profiles/usaa-os-browser
USAA_OS_LOGIN_TIMEOUT_SECONDS=90

# Dev: swap the active carrier flow for a deterministic mock (no real network)
CARRIER_MOCK=false
MOCK_BAD_PASSWORD=false
MOCK_BAD_MFA=false
MOCK_SKIP_MFA=false
MOCK_QUICK_PATH_OK=true

# Credentials for the live smoke tests (tests/test_*_smoke.py)
GEICO_USERNAME=
GEICO_PASSWORD=
PROGRESSIVE_USERNAME=
PROGRESSIVE_PASSWORD=
ALLSTATE_USERNAME=
ALLSTATE_PASSWORD=
STATE_FARM_USERNAME=
STATE_FARM_PASSWORD=
MERCURY_USERNAME=
MERCURY_PASSWORD=
USAA_USERNAME=
USAA_PASSWORD=
USAA_MFA_EMAIL=

# Optional hosted mode: leave empty for normal local automation. Set on the
# hosted app to route selected carrier work to a trusted local worker.
WORKER_BASE_URL=
WORKER_PROXY_CARRIERS=usaa
USAA_WORKER_BASE_URL=

# Convenience: when true, GET /api/dev/credentials returns the env-saved
# creds so the UI can pre-fill the form during local demos. Leave off in prod.
DEV_PREFILL_CREDS=false
